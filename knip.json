    "apps/api/src/**/*.module.ts",
    "apps/dashboard/src/app/layout.tsx",
    "apps/dashboard/src/app/**/page.tsx",
    "apps/dashboard/src/app/**/layout.tsx",
    "apps/dashboard/src/app/**/loading.tsx",
    "apps/dashboard/src/app/**/route.ts",
    "libs/**/src/index.ts",
