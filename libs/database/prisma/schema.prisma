generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres@127.0.0.1:5432/omnicore?schema=public"
}

model SalesChannel {
  id               String            @id @default(uuid())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  products         Product[]
  orders           Order[]
  stockMovements   StockMovement[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
}

model Category {
  id        String     @id @default(uuid())
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id             String           @id @default(uuid())
  name           String
  description    String?
  technicalSpecs Json?
  channelId      String
  categoryId     String?
  brandId        String?
  channel        SalesChannel     @relation(fields: [channelId], references: [id])
  category       Category?        @relation(fields: [categoryId], references: [id])
  brand          Brand?           @relation(fields: [brandId], references: [id])
  variants       ProductVariant[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ProductVariant {
  id                String  @id @default(uuid())
  productId         String
  sku               String  @unique
  barcode           String? @unique
  price             Float
  stock             Int     @default(0)
  movingAverageCost Decimal @default(0)
  attributes        Json? // e.g., {"color": "Red", "size": "M"} or {"volume": "400ml"}
  technicalSpecs    Json? // Variant specific specs
  desi              Float?
  weight            Float?
  dimensions        Json? // e.g., {"width": 10, "height": 20, "depth": 5}

  isBundle      Boolean           @default(false)
  bundleItems   BundleComponent[] @relation("ParentVariant")
  partOfBundles BundleComponent[] @relation("ChildVariant")

  product              Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  stockMovements       StockMovement[]
  purchaseOrderItems   PurchaseOrderItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
}

model BundleComponent {
  id              String @id @default(uuid())
  parentVariantId String
  childVariantId  String
  quantity        Int

  parentVariant ProductVariant @relation("ParentVariant", fields: [parentVariantId], references: [id], onDelete: Cascade)
  childVariant  ProductVariant @relation("ChildVariant", fields: [childVariantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentVariantId, childVariantId])
}

enum SettlementStatus {
  PENDING
  CALCULATED
  RECONCILED
}

enum StockMovementEventType {
  SALE
  RESTOCK
  CANCEL
  RETURN
  MANUAL_ADJUST
}

model StockMovement {
  id               String                 @id @default(uuid())
  productVariantId String
  channelId        String?
  eventType        StockMovementEventType
  quantityChange   Int
  unitCost         Decimal?
  referenceId      String?
  createdAt        DateTime               @default(now())

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  channel        SalesChannel?  @relation(fields: [channelId], references: [id])
}

model Order {
  id               String           @id @default(uuid())
  orderNumber      String           @unique
  totalAmount      Decimal
  costPrice        Decimal          @default(0)
  commissionAmount Decimal          @default(0)
  shippingCost     Decimal          @default(0)
  taxAmount        Decimal          @default(0)
  discountAmount   Decimal          @default(0)
  netProfit        Decimal          @default(0)
  settlementStatus SettlementStatus @default(PENDING)
  status           String
  invoiceStatus    String?
  invoicePdfUrl    String?
  shippingLabelUrl String?
  channelId        String?
  channel          SalesChannel?    @relation(fields: [channelId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Supplier {
  id               String            @id @default(uuid())
  name             String
  supplierGroup    String?
  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // General & Contact
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?

  // Address (UBL-TR)
  streetAddress String?
  city          String?
  district      String?
  postalCode    String?
  country       String? @default("Türkiye")

  // Finance & E-Transformation
  taxNumber       String?
  taxOffice       String?
  currency        String  @default("TRY")
  iban            String?
  bankName        String?
  paymentTerms    Int?
  eInvoiceAlias   String?
  naceCode        String?
  mersisNo        String?
  tradeRegistryNo String?

  // Logistics & Operation
  leadTimeInDays       Int     @default(1)
  minimumOrderQuantity Int     @default(1)
  isActive             Boolean @default(true)
  isDropshipper        Boolean @default(false)
  returnAddress        String?

  // External System & Performance
  externalSellerId String?
  performanceScore Int?
  salesChannel     SalesChannel? @relation(fields: [salesChannelId], references: [id])
  salesChannelId   String?
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL_RECEIPT
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  supplierId     String
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  status         PurchaseOrderStatus @default(DRAFT)
  orderDate      DateTime            @default(now())
  totalAmount    Decimal
  items          PurchaseOrderItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  salesChannel   SalesChannel?       @relation(fields: [salesChannelId], references: [id])
  salesChannelId String?
}

model PurchaseOrderItem {
  id               String         @id @default(uuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int
  unitCost         Decimal
  totalCost        Decimal
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum PurchaseInvoiceStatus {
  DRAFT
  MATCHING_PENDING
  COMPLETED
}

enum PurchaseInvoiceType {
  E_INVOICE
  E_ARCHIVE
}

model PurchaseInvoice {
  id           String              @id @default(uuid())
  documentNo   String
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  date         DateTime
  dueDate      DateTime?
  type         PurchaseInvoiceType @default(E_INVOICE)
  currency     String              @default("TRY")
  exchangeRate Decimal             @default(1)

  // Financial Summary
  subTotal               Decimal @default(0)
  generalDiscountPercent Decimal @default(0)
  generalDiscountAmount  Decimal @default(0)
  taxAmount              Decimal @default(0)
  roundingDifference     Decimal @default(0)
  grandTotal             Decimal @default(0)

  notes String?

  status PurchaseInvoiceStatus @default(DRAFT)

  items PurchaseInvoiceItem[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  salesChannel   SalesChannel? @relation(fields: [salesChannelId], references: [id])
  salesChannelId String?
}

model PurchaseInvoiceItem {
  id                String          @id @default(uuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  name            String
  quantity        Decimal
  unit            String  @default("Adet")
  unitPrice       Decimal
  discountPercent Decimal @default(0)
  totalAmount     Decimal

  isMatched      Boolean         @default(false)
  matchedSku     String?
  productId      String?
  productVariant ProductVariant? @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
