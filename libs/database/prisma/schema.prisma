generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SalesChannel {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
  orders    Order[]
}

model Product {
  id         String       @id @default(uuid())
  name       String
  sku        String       @unique
  price      Float
  channelId  String
  channel    SalesChannel @relation(fields: [channelId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Order {
  id          String       @id @default(uuid())
  orderNumber String       @unique
  totalAmount Float
  status      String
  channelId   String
  channel     SalesChannel @relation(fields: [channelId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
