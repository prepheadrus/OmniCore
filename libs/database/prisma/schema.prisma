generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:postgres@127.0.0.1:5432/omnicore?schema=public"
}

model SalesChannel {
  id                         String                 @id @default(uuid())
  name                       String
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  products                   Product[]
  orders                     Order[]
  stockMovements             StockMovement[]
  suppliers                  Supplier[]
  purchaseOrders             PurchaseOrder[]
  purchaseInvoices           PurchaseInvoice[]
  users_list                 User[]
  licenses_list              License[]
  notifications_list         Notification[]
  automationRules_list       AutomationRule[]
  returns_list               Return[]
  customers_list             Customer[]
  integrations_list          Integration[]
  invoices_list              Invoice[]
  shipments_list             Shipment[]
  warehouses_list            Warehouse[]
  campaigns_list             Campaign[]
  auditLogs_list             AuditLog[]
  backgroundJobs_list        BackgroundJob[]
  productFeeds_list          ProductFeed[]
  priceRules_list            PriceRule[]
  contentRules_list          ContentRule[]
  feedTemplates_list         FeedTemplate[]
  stockSyncLogs_list         StockSyncLog[]
  feedQualityRules_list      FeedQualityRule[]
  priceHistorys_list         PriceHistory[]
  webhookEndpoints_list      WebhookEndpoint[]
  competitorPrices_list      CompetitorPrice[]
  adCampaigns_list           AdCampaign[]
  seoAnalysiss_list          SeoAnalysis[]
  exchangeRates_list         ExchangeRate[]
  inventoryForecasts_list    InventoryForecast[]
  listingQualityScores_list  ListingQualityScore[]
  carrierRates_list          CarrierRate[]
  emailCampaigns_list        EmailCampaign[]
  abTests_list               AbTest[]
  dropshipOrders_list        DropshipOrder[]
  productBundles_list        ProductBundle[]
  buyBoxAnalysiss_list       BuyBoxAnalysis[]
  b2BCustomers_list          B2BCustomer[]
  b2BOrders_list             B2BOrder[]
  repricerRules_list         RepricerRule[]
  repricerLogs_list          RepricerLog[]
  smartOrderRules_list       SmartOrderRule[]
  sellerPerformances_list    SellerPerformance[]
  barcodeScans_list          BarcodeScan[]
  socialListings_list        SocialListing[]
  aiContentJobs_list         AiContentJob[]
  brandProtectionAlerts_list BrandProtectionAlert[]
  smartAlertRules_list       SmartAlertRule[]
  productLaunchs_list        ProductLaunch[]
  taxComplianceRules_list    TaxComplianceRule[]
  profitSimulations_list     ProfitSimulation[]
  microExports_list          MicroExport[]

  chatConversations_list ChatConversation[]
  chatMessages_list      ChatMessage[]
  categoryMappings_list  CategoryMapping[]
}

model Category {
  id        String     @id @default(uuid())
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id             String           @id @default(uuid())
  name           String
  description    String?
  technicalSpecs Json?
  channelId      String
  categoryId     String?
  brandId        String?
  channel        SalesChannel     @relation(fields: [channelId], references: [id])
  category       Category?        @relation(fields: [categoryId], references: [id])
  brand          Brand?           @relation(fields: [brandId], references: [id])
  variants       ProductVariant[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sku            String?          @unique
  barcode        String?
  price          Float?
  stock          Int?
  cost           Float?
  subCategory    String           @default("")
  marketplace    String           @default("")
  shortDesc      String           @default("")
  images         String[]
  attributes     Json             @default("{}")
  seoTitle       String           @default("")
  seoDesc        String           @default("")
  supplierId     String           @default("")
  minStock       Int              @default(0)
  weight         Float            @default(0)
  dimensions     Json             @default("{}")
  vatRate        Float            @default(20)
  cargoTemplate  String           @default("standart")
  isActive       Boolean          @default(true)
  isListed       Boolean          @default(false)
  listings       Json             @default("{}")
  stockReserve   Int              @default(0)
  gtin           String           @default("")
  mpn            String           @default("")
}

model ProductVariant {
  id                String  @id @default(uuid())
  productId         String
  sku               String  @unique
  barcode           String? @unique
  price             Float
  stock             Int     @default(0)
  movingAverageCost Decimal @default(0)
  attributes        Json? // e.g., {"color": "Red", "size": "M"} or {"volume": "400ml"}
  technicalSpecs    Json? // Variant specific specs
  desi              Float?
  weight            Float?
  dimensions        Json? // e.g., {"width": 10, "height": 20, "depth": 5}

  isBundle      Boolean           @default(false)
  bundleItems   BundleComponent[] @relation("ParentVariant")
  partOfBundles BundleComponent[] @relation("ChildVariant")

  product              Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  stockMovements       StockMovement[]
  purchaseOrderItems   PurchaseOrderItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
}

model BundleComponent {
  id              String @id @default(uuid())
  parentVariantId String
  childVariantId  String
  quantity        Int

  parentVariant ProductVariant @relation("ParentVariant", fields: [parentVariantId], references: [id], onDelete: Cascade)
  childVariant  ProductVariant @relation("ChildVariant", fields: [childVariantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentVariantId, childVariantId])
}

enum SettlementStatus {
  PENDING
  CALCULATED
  RECONCILED
}

enum StockMovementEventType {
  SALE
  RESTOCK
  CANCEL
  RETURN
  MANUAL_ADJUST
}

model StockMovement {
  id               String                 @id @default(uuid())
  productVariantId String
  channelId        String?
  eventType        StockMovementEventType
  quantityChange   Int
  unitCost         Decimal?
  referenceId      String?
  createdAt        DateTime               @default(now())

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  channel        SalesChannel?  @relation(fields: [channelId], references: [id])
}

model Order {
  id                 String           @id @default(uuid())
  orderNumber        String           @unique
  totalAmount        Decimal
  costPrice          Decimal          @default(0)
  commissionAmount   Decimal          @default(0)
  shippingCost       Decimal          @default(0)
  taxAmount          Decimal          @default(0)
  discountAmount     Decimal          @default(0)
  netProfit          Decimal          @default(0)
  settlementStatus   SettlementStatus @default(PENDING)
  status             String
  invoiceStatus      String?
  invoicePdfUrl      String?
  shippingLabelUrl   String?
  channelId          String?
  channel            SalesChannel?    @relation(fields: [channelId], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  marketplace        String           @default("")
  marketplaceOrderNo String           @default("")
  customerName       String?
  customerEmail      String           @default("")
  customerPhone      String           @default("")
  discount           Float            @default(0)
  netAmount          Float            @default(0)
  commission         Float            @default(0)
  cargoCost          Float            @default(0)
  items              Int              @default(1)
  itemsJson          Json             @default("[]")
  notes              String           @default("")
  shippingAddr       String           @default("")
  billingAddr        String           @default("")
  invoiceNo          String           @default("")
  trackingNo         String           @default("")
  carrier            String           @default("")
  cancelReason       String           @default("")
}

model Supplier {
  id               String            @id @default(uuid())
  name             String
  supplierGroup    String?
  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // General & Contact
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?

  // Address (UBL-TR)
  streetAddress String?
  city          String?
  district      String?
  postalCode    String?
  country       String? @default("Türkiye")

  // Finance & E-Transformation
  taxNumber       String?
  taxOffice       String?
  currency        String  @default("TRY")
  iban            String?
  bankName        String?
  paymentTerms    Int?
  eInvoiceAlias   String?
  naceCode        String?
  mersisNo        String?
  tradeRegistryNo String?

  // Logistics & Operation
  leadTimeInDays       Int     @default(1)
  minimumOrderQuantity Int     @default(1)
  isActive             Boolean @default(true)
  isDropshipper        Boolean @default(false)
  returnAddress        String?

  // External System & Performance
  externalSellerId String?
  performanceScore Int?
  salesChannel     SalesChannel? @relation(fields: [salesChannelId], references: [id])
  salesChannelId   String?
  contact          String        @default("")
  phone            String        @default("")
  email            String        @default("")
  address          String        @default("")
  rating           Int           @default(0)
  leadTime         Int           @default(0)
  totalOrders      Int           @default(0)
  totalSpent       Float         @default(0)
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL_RECEIPT
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  supplierId     String
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  status         PurchaseOrderStatus @default(DRAFT)
  orderDate      DateTime            @default(now())
  totalAmount    Decimal
  items          PurchaseOrderItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  salesChannel   SalesChannel?       @relation(fields: [salesChannelId], references: [id])
  salesChannelId String?

  poNumber     String?   @unique
  supplierName String?   @default("")
  currency     String?   @default("TRY")
  expectedDate DateTime?
  receivedDate DateTime?
  notes        String?   @default("")
}

model PurchaseOrderItem {
  id               String         @id @default(uuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int
  unitCost         Decimal
  totalCost        Decimal
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum PurchaseInvoiceStatus {
  DRAFT
  MATCHING_PENDING
  COMPLETED
}

enum PurchaseInvoiceType {
  E_INVOICE
  E_ARCHIVE
}

model PurchaseInvoice {
  id           String              @id @default(uuid())
  documentNo   String
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  date         DateTime
  dueDate      DateTime?
  type         PurchaseInvoiceType @default(E_INVOICE)
  currency     String              @default("TRY")
  exchangeRate Decimal             @default(1)

  // Financial Summary
  subTotal               Decimal @default(0)
  generalDiscountPercent Decimal @default(0)
  generalDiscountAmount  Decimal @default(0)
  taxAmount              Decimal @default(0)
  roundingDifference     Decimal @default(0)
  grandTotal             Decimal @default(0)

  notes String?

  status PurchaseInvoiceStatus @default(DRAFT)

  items PurchaseInvoiceItem[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  salesChannel   SalesChannel? @relation(fields: [salesChannelId], references: [id])
  salesChannelId String?
}

model PurchaseInvoiceItem {
  id                String          @id @default(uuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  name            String
  quantity        Decimal
  unit            String  @default("Adet")
  unitPrice       Decimal
  discountPercent Decimal @default(0)
  totalAmount     Decimal

  isMatched      Boolean         @default(false)
  matchedSku     String?
  productId      String?
  productVariant ProductVariant? @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  name          String
  role          String        @default("viewer")
  avatar        String        @default("")
  phone         String        @default("")
  isActive      Boolean       @default(true)
  twoFactor     Boolean       @default(false)
  twoFactorCode String        @default("")
  lastLogin     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  channelId     String?
  channel       SalesChannel? @relation(fields: [channelId], references: [id])
}

model License {
  id          String        @id @default(cuid())
  key         String        @unique
  status      String        @default("inactive")
  licenseType String        @default("trial")
  ownerName   String        @default("")
  ownerEmail  String        @default("")
  company     String        @default("")
  activatedAt DateTime?
  expiresAt   DateTime?
  machineId   String        @default("")
  features    String        @default("all")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  channelId   String?
  channel     SalesChannel? @relation(fields: [channelId], references: [id])
}

model Notification {
  id        String        @id @default(cuid())
  userId    String        @default("default")
  type      String        @default("info")
  title     String
  message   String
  link      String        @default("")
  isRead    Boolean       @default(false)
  category  String        @default("system")
  createdAt DateTime      @default(now())
  channelId String?
  channel   SalesChannel? @relation(fields: [channelId], references: [id])
}

model AutomationRule {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  trigger     String        @default("")
  condition   Json          @default("{}")
  action      String        @default("")
  actionData  Json          @default("{}")
  isActive    Boolean       @default(true)
  runCount    Int           @default(0)
  lastRun     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  channelId   String?
  channel     SalesChannel? @relation(fields: [channelId], references: [id])
}

model Return {
  id           String        @id @default(cuid())
  returnNumber String        @unique
  orderNumber  String
  customerName String
  reason       String        @default("")
  status       String        @default("pending")
  totalAmount  Float
  refundAmount Float         @default(0)
  type         String        @default("full")
  items        Int           @default(1)
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  channelId    String?
  channel      SalesChannel? @relation(fields: [channelId], references: [id])
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  email         String        @default("")
  phone         String        @default("")
  city          String        @default("")
  district      String        @default("")
  segment       String        @default("new")
  loyaltyScore  Int           @default(0)
  totalOrders   Int           @default(0)
  totalSpent    Float         @default(0)
  avgOrderValue Float         @default(0)
  lastOrderAt   DateTime?
  notes         String        @default("")
  tags          String[]
  taxNo         String        @default("")
  taxOffice     String        @default("")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  channelId     String?
  channel       SalesChannel? @relation(fields: [channelId], references: [id])
}

model Integration {
  id         String        @id @default(cuid())
  name       String
  type       String        @default("marketplace")
  platform   String        @default("")
  status     String        @default("disconnected")
  apiKey     String        @default("")
  apiSecret  String        @default("")
  shopUrl    String        @default("")
  config     Json          @default("{}")
  lastSync   DateTime?
  syncStats  Json          @default("{}")
  errorCount Int           @default(0)
  lastError  String        @default("")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  channelId  String?
  channel    SalesChannel? @relation(fields: [channelId], references: [id])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  customerName  String
  type          String        @default("sales")
  amount        Float
  tax           Float         @default(0)
  status        String        @default("draft")
  date          DateTime      @default(now())
  xmlUrl        String        @default("")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  channelId     String?
  channel       SalesChannel? @relation(fields: [channelId], references: [id])
}

model Shipment {
  id             String        @id @default(cuid())
  trackingNumber String        @default("")
  orderNumber    String
  carrier        String
  status         String        @default("pending")
  customerName   String
  address        String        @default("")
  labelUrl       String        @default("")
  cargoCost      Float         @default(0)
  weight         Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  channelId      String?
  channel        SalesChannel? @relation(fields: [channelId], references: [id])
}

model Warehouse {
  id        String        @id @default(cuid())
  name      String
  code      String        @default("")
  address   String        @default("")
  capacity  Int           @default(0)
  usedSpace Int           @default(0)
  type      String        @default("standard")
  status    String        @default("active")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  channelId String?
  channel   SalesChannel? @relation(fields: [channelId], references: [id])
}

model Campaign {
  id          String        @id @default(cuid())
  name        String
  type        String        @default("discount")
  marketplace String        @default("")
  discount    Float         @default(0)
  startDate   DateTime
  endDate     DateTime
  status      String        @default("draft")
  productIds  String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  channelId   String?
  channel     SalesChannel? @relation(fields: [channelId], references: [id])
}

model AuditLog {
  id        String        @id @default(cuid())
  userId    String        @default("")
  userName  String        @default("")
  action    String
  entity    String        @default("")
  entityId  String        @default("")
  details   String        @default("")
  createdAt DateTime      @default(now())
  channelId String?
  channel   SalesChannel? @relation(fields: [channelId], references: [id])
}

model BackgroundJob {
  id        String        @id @default(cuid())
  type      String
  status    String        @default("pending")
  payload   Json          @default("{}")
  result    String        @default("")
  progress  Int           @default(0)
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime      @default(now())
  channelId String?
  channel   SalesChannel? @relation(fields: [channelId], references: [id])
}

model ProductFeed {
  id            String        @id @default(cuid())
  name          String
  source        String        @default("upload")
  sourceUrl     String        @default("")
  format        String        @default("xml")
  status        String        @default("active")
  schedule      String        @default("manual")
  lastImport    DateTime?
  lastError     String        @default("")
  totalProducts Int           @default(0)
  validProducts Int           @default(0)
  errorProducts Int           @default(0)
  fieldMapping  Json          @default("{}")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  channelId     String?
  channel       SalesChannel? @relation(fields: [channelId], references: [id])
}

model PriceRule {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  type        String        @default("markup")
  baseField   String        @default("cost")
  value       Float         @default(0)
  valueType   String        @default("percentage")
  minMargin   Float         @default(0)
  maxPrice    Float         @default(0)
  roundTo     Float         @default(0)
  marketplace String        @default("")
  categoryId  String        @default("")
  isActive    Boolean       @default(true)
  priority    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  channelId   String?
  channel     SalesChannel? @relation(fields: [channelId], references: [id])
}

model CategoryMapping {
  id        String        @id @default(cuid())
  source    String        @default("")
  sourceCat String        @default("")
  target    String        @default("")
  targetCat String        @default("")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  channelId String?
  channel   SalesChannel? @relation(fields: [channelId], references: [id])
}

model ContentRule {
  id          String        @id @default(cuid())
  name        String
  type        String        @default("title_template")
  channelName String        @default("all")
  category    String        @default("")
  description String        @default("")
  template    String        @default("")
  variables   Json          @default("{}")
  isActive    Boolean       @default(true)
  priority    Int           @default(0)
  applyCount  Int           @default(0)
  lastApplied DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  channelId   String?
  channel     SalesChannel? @relation(fields: [channelId], references: [id])
}

model FeedTemplate {
  id            String        @id @default(cuid())
  name          String
  description   String        @default("")
  platform      String        @default("")
  format        String        @default("xml")
  category      String        @default("")
  fields        Json          @default("[]")
  requirements  Json          @default("{}")
  sampleUrl     String        @default("")
  isPopular     Boolean       @default(false)
  downloadCount Int           @default(0)
  rating        Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  channelId     String?
  channel       SalesChannel? @relation(fields: [channelId], references: [id])
}

model StockSyncLog {
  id          String        @id @default(cuid())
  productId   String        @default("")
  productName String        @default("")
  sku         String        @default("")
  channelName String        @default("")
  oldStock    Int           @default(0)
  newStock    Int           @default(0)
  status      String        @default("success")
  error       String        @default("")
  triggeredBy String        @default("manual")
  createdAt   DateTime      @default(now())
  channelId   String?
  channel     SalesChannel? @relation(fields: [channelId], references: [id])
}

model FeedQualityRule {
  id          String        @id @default(cuid())
  name        String
  type        String        @default("required_field")
  field       String        @default("")
  condition   String        @default("")
  severity    String        @default("error")
  channelName String        @default("all")
  category    String        @default("")
  isActive    Boolean       @default(true)
  errorCount  Int           @default(0)
  lastCheck   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  channelId   String?
  channel     SalesChannel? @relation(fields: [channelId], references: [id])
}

model PriceHistory {
  id          String        @id @default(cuid())
  productId   String        @default("")
  productName String        @default("")
  sku         String        @default("")
  oldPrice    Float         @default(0)
  newPrice    Float         @default(0)
  ruleApplied String        @default("")
  marketplace String        @default("")
  changedBy   String        @default("auto")
  createdAt   DateTime      @default(now())
  channelId   String?
  channel     SalesChannel? @relation(fields: [channelId], references: [id])
}

model WebhookEndpoint {
  id            String        @id @default(cuid())
  name          String
  url           String
  secret        String        @default("")
  events        Json          @default("[]")
  isActive      Boolean       @default(true)
  successCount  Int           @default(0)
  failCount     Int           @default(0)
  lastTriggered DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  channelId     String?
  channel       SalesChannel? @relation(fields: [channelId], references: [id])
}

model ChatConversation {
  id            String        @id @default(cuid())
  customerName  String        @default("")
  customerEmail String        @default("")
  subject       String        @default("")
  status        String        @default("active")
  assignedTo    String        @default("")
  priority      String        @default("normal")
  channelName   String        @default("widget")
  tags          String[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  messages      ChatMessage[]
  channelId     String?
  channel       SalesChannel? @relation(fields: [channelId], references: [id])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  sender         String           @default("customer")
  senderName     String           @default("")
  content        String
  type           String           @default("text")
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
